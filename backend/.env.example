# INDRA Backend — environment template
# Copy to .env and fill in values before deploying

# Neon PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=

# CORS — frontend URLs (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# Data mode: "synthetic" (Phase 1) or "live" (Phase 2+)
DATA_MODE=synthetic

# AISstream free tier key (get at aisstream.io)
AISSTREAM_API_KEY=

# EIA Open Data API key (get at eia.gov/opendata)
EIA_API_KEY=

# Anthropic API key for Copilot (Phase 3)
ANTHROPIC_API_KEY=

# Environment label
ENVIRONMENT=production
